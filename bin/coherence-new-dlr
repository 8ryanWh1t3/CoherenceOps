#!/usr/bin/env bash
set -euo pipefail

# coherence-new-dlr — Create a new DLR with date-based ID
# Usage: ./coherence-new-dlr "Title of Decision"
# Always writes to coherence/decisions/ (production only).

# Safety guard: refuse to create files when running against sample data
COHERENCE_ROOT="${COHERENCE_ROOT:-coherence}"
if [ "$COHERENCE_ROOT" != "coherence" ]; then
  echo "ERROR: coherence-new-dlr is a production-only tool."
  echo "       COHERENCE_ROOT is set to '${COHERENCE_ROOT}' — refusing to create files."
  echo "       Unset COHERENCE_ROOT or set it to 'coherence' to create new DLRs."
  exit 1
fi

DIR="coherence/decisions"
INDEX="$DIR/INDEX.md"
TODAY=$(date +%Y%m%d)
TITLE="${1:-Untitled Decision}"

# Find next suffix for today
SUFFIX=1
while [ -f "$DIR/DLR-${TODAY}-$(printf '%03d' $SUFFIX).md" ]; do
  SUFFIX=$((SUFFIX + 1))
done

ID="DLR-${TODAY}-$(printf '%03d' $SUFFIX)"
FILE="$DIR/${ID}.md"
DATE_FMT=$(date +%Y-%m-%d)

cat > "$FILE" <<EOF
# ${ID}: ${TITLE}

## Status
Draft

## Context
What problem are we solving? Why now?

## Options Considered
1. **Option A** -- ...
2. **Option B** -- ...

## Decision
What we chose and why.

## Trade-offs
What we gave up.

## Assumptions
- ASM-NNNN

## Blast Radius
Scope of impact if wrong.

## Rollback
How to reverse this.

## Owner
@TODO

## Date
${DATE_FMT}
EOF

echo "Created: $FILE"

# Append to INDEX
if [ ! -f "$INDEX" ]; then
  cat > "$INDEX" <<'INDEXEOF'
# Decision Ledger Index

| Date | ID | Title | Owner | Status |
|------|----|-------|-------|--------|
INDEXEOF
fi

echo "| ${DATE_FMT} | [${ID}](${ID}.md) | ${TITLE} | @TODO | Draft |" >> "$INDEX"
echo "Updated: $INDEX"
